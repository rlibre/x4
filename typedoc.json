{
	"entryPointStrategy": "resolve",
	"out": "docs",
	"name": "x4js",
	"includeVersion": true,
	"tsconfig": "tsconfig.json", 
	"navigationLinks": {
		"GitHub": "https://github.com/rlibre/x4"
	},
	"excludePrivate": true,
	"excludeInternal": true,
	"excludeExternals": true,
	"readme": "README.md",
  	"plugin": ["typedoc-plugin-missing-exports"],
  	"entryPoints": ["src/x4doc.ts"],
	"exclude": [ "src/components/monaco", "publish.ts" ]
}